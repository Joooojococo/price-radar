# 數據來源：使用 Binance 公開 API（無需帳號、無需 API Key）
# 完全免費，無需申請任何帳號

# DeepSeek API 配置（語義化過濾，必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# Telegram Bot 配置（極速推送）
TELEGRAM_BOT_TOKEN=8649094676:AAFlFaan4ahQl1vZfDG5-1rLsgThFCKFqNw
TELEGRAM_CHAT_ID=949100281
SYMBOL=BTCUSDT
CVD_SLOPE_THRESHOLD=0.08
# n8n Webhook URL（數據紀錄）
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/btc-alert
# TradingView 圖表 URL
TRADINGVIEW_CHART_URL=https://www.tradingview.com/chart/your-chart-id/
# 監控參數
INTERVAL_1M=1m
INTERVAL_15M=15m
SCAN_INTERVAL=1
# Vegas 隧道參數
EMA_FAST=144
EMA_SLOW=169
# CVD 參數
CVD_LOOKBACK_MINUTES=5
# DeepSeek 過濾參數
DEEPSEEK_CONFIDENCE_THRESHOLD=7
DEEPSEEK_TIMEOUT=5
# 觸發冷卻時間（秒）
ALERT_COOLDOWN=180
# 截圖參數（手機直向）
SCREENSHOT_WIDTH=800
SCREENSHOT_HEIGHT=1200
SCREENSHOT_HIDE_UI=true
# 語音警報
VOICE_ALERT_ENABLED=true
VOICE_LANGUAGE=zh-TW
ULTRA_STRONG_ONLY=true
